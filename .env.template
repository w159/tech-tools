# =====================================================================
# MCP server credential template
#
# Copy to .env and fill in for the servers you want to test:
#     cp .env.template .env
#
# Then run end-to-end verification:
#     node test-mcp-tools.mjs           # exercise all servers
#     node test-mcp-tools.mjs auvik     # exercise one server
#
# Empty values are treated as "skip this server" by test-mcp-tools.mjs.
# =====================================================================

# ---------- Auvik (network monitoring) ----------
# Username + API key from Auvik portal.
# AUVIK_REGION: leave blank to use the default region (us1).
# Valid values: us1, us2, us3, us4, eu1, eu2, au1, ca1.
AUVIK_USERNAME=
AUVIK_API_KEY=
AUVIK_REGION=

# ---------- Blumira (SIEM) ----------
# Long-lived JWT from Blumira portal -> Integrations -> API.
BLUMIRA_JWT_TOKEN=
# OAuth2 client credentials (alternative to JWT -- set these if using the OAuth flow).
BLUMIRA_CLIENT_ID=
BLUMIRA_CLIENT_SECRET=
# BASE_URL is optional. Leave blank to use the vendor default (https://api.blumira.com/public-api/v1).
# Only set for staging/sovereign shards.
BLUMIRA_BASE_URL=

# ---------- CIPP (M365 management) ----------
# Either CIPP_API_KEY (legacy static bearer) OR the OAuth trio
# (CIPP_TENANT_ID + CIPP_CLIENT_ID + CIPP_CLIENT_SECRET). Base URL is required.
CIPP_BASE_URL=
CIPP_API_KEY=
CIPP_TENANT_ID=
CIPP_CLIENT_ID=
CIPP_CLIENT_SECRET=

# ---------- ConnectWise Manage (PSA) ----------
CW_MANAGE_COMPANY_ID=
CW_MANAGE_PUBLIC_KEY=
CW_MANAGE_PRIVATE_KEY=
CW_MANAGE_CLIENT_ID=
# CW_MANAGE_BASE_URL: leave blank to use the NA cloud default (https://api-na.myconnectwise.net).
# Set for other regions: https://api-eu.myconnectwise.net, https://api-au.myconnectwise.net
# or your self-hosted URL, e.g. https://cwm.yourcompany.com.
CW_MANAGE_BASE_URL=

# ---------- KnowBe4 (security awareness) ----------
# API key from KnowBe4 -> Account Settings -> API.
# KNOWBE4_REGION: leave blank to use the default (us → https://us.api.knowbe4.com).
# Valid values: us, eu, ca, uk, de.
KNOWBE4_API_KEY=
KNOWBE4_REGION=

# ---------- NinjaOne (RMM) ----------
# Two auth modes:
#   NINJAONE_AUTH_MODE=client_credentials  (default) — needs client_id + client_secret
#   NINJAONE_AUTH_MODE=user                — needs client_id only; refresh token stored
#                                            at ~/.tech-tools/ninjaone-tokens.json
#                                            after running the ninjaone_sign_in tool.
#                                            Your NinjaOne OAuth app must list
#                                            http://127.0.0.1:53682/oauth/callback
#                                            as a redirect URI.
# NINJAONE_REGION: leave blank to use the default (us -> https://app.ninjarmm.com).
# Valid values: us, eu, ca, oc, us2, fed.
# NINJAONE_BASE_URL: leave blank to use the vendor default (https://app.ninjarmm.com).
# Only set for non-default regions or self-hosted instances not covered by NINJAONE_REGION.
NINJAONE_CLIENT_ID=
NINJAONE_CLIENT_SECRET=
NINJAONE_REGION=
NINJAONE_AUTH_MODE=
NINJAONE_BASE_URL=

# ---------- ThreatLocker (zero-trust EDR) ----------
# API key from Portal -> Administrators -> API Users.
# ORGANIZATION_ID is OPTIONAL (only required when acting on a child managed org).
# BASE_URL is OPTIONAL. Leave blank to use the vendor default (https://portalapi.g.threatlocker.com/portalapi).
# Only set if your tenant lives on a non-default shard;
# see https://threatlocker.kb.help/locating-your-organizations-instance/
THREATLOCKER_API_KEY=
THREATLOCKER_ORGANIZATION_ID=
THREATLOCKER_BASE_URL=

# ---------- Vanta (GRC / compliance) ----------
# OAuth2 client_credentials from Vanta -> Settings -> API Tokens.
# CLIENT_ID + CLIENT_SECRET are required; BASE_URL is optional (defaults to
# https://api.vanta.com/v1 — only override if Vanta has moved you to a
# non-default shard). Tokens are minted on demand and cached for ~1 hour;
# the token endpoint is limited to 5 req/min so reuse is critical.
VANTA_CLIENT_ID=
VANTA_CLIENT_SECRET=
# VANTA_BASE_URL: leave blank to use the vendor default (https://api.vanta.com/v1).
# Only set for staging/sovereign shards. Tokens are minted on demand and cached ~1h;
# the token endpoint is limited to 5 req/min so avoid restarting the server in a loop.
VANTA_BASE_URL=

# ---------- Paylocity (HR/payroll) ----------
# OAuth2 client_credentials from Paylocity developer portal.
# CLIENT_ID + CLIENT_SECRET are required. Token endpoint uses
# form-urlencoded body and tokens are cached for ~1 hour.
# COMPANY_ID is required to scope tool calls without passing companyId
# per call (every Paylocity API path embeds it).
# BASE_URL is optional. Leave blank to use the vendor default (https://api.paylocity.com).
# Set ONLY the host root (no /api/v2 or /corehr suffix) - the client appends the
# correct path per endpoint family.
# Only set for staging or if Paylocity assigns a non-standard endpoint.
# SANDBOX=true switches to https://apisandbox.paylocity.com (ignored if BASE_URL is set).
PAYLOCITY_CLIENT_ID=
PAYLOCITY_CLIENT_SECRET=
PAYLOCITY_COMPANY_ID=
PAYLOCITY_BASE_URL=
PAYLOCITY_SANDBOX=

# ---------- Kaseya Spanning Backup (SaaS backup for M365/GWS/Salesforce) ----------
# Admin email + API token from the Spanning admin console. Tokens are
# pair-bound to the admin email — any mismatch surfaces as a generic 401.
# SPANNING_PLATFORM: leave blank to use the default (m365 → https://o365-api.spanningbackup.com/external).
# Valid values: m365, gws (→ https://api.spanningbackup.com/external), salesforce (→ https://salesforce-api.spanningbackup.com).
# SPANNING_API_URL: leave blank — URL is derived automatically from SPANNING_PLATFORM.
# Only set for staging shards.
SPANNING_ADMIN_EMAIL=
SPANNING_API_TOKEN=
SPANNING_PLATFORM=
SPANNING_API_URL=

# ---------- Pax8 (cloud marketplace / distributor) ----------
# MCP token from app.pax8.com -> Integrations -> MCP.
# Server URL is the Pax8 hosted default (https://mcp.pax8.com/v1/mcp) -- no BASE_URL needed.
PAX8_MCP_TOKEN=

# ---------- PandaDoc (document automation) ----------
# API key from app.pandadoc.com -> Settings -> Integrations -> API.
# Server URL is the PandaDoc hosted default (https://developers.pandadoc.com/mcp) -- no BASE_URL needed.
PANDADOC_API_KEY=
