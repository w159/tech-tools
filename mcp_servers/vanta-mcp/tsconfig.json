{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "sourceMap": true,
    "paths": {
      "@shared/*": [
        "../../_shared/*"
      ]
    }
  },
  "include": [
    "src",
    "../_shared/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}