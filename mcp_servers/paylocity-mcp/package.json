{
  "name": "paylocity-mcp",
  "version": "0.1.0",
  "description": "MCP server for the Paylocity REST API (HR / payroll)",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "paylocity-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "pack:mcpb": "node scripts/pack-mcpb.js"
  },
  "keywords": [
    "paylocity",
    "mcp",
    "hr",
    "payroll",
    "hcm",
    "model-context-protocol"
  ],
  "author": "w159",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "node-paylocity": "file:../../mcp_node/node-paylocity"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
