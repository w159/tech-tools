  "bugs": {
    "url": "https://github.com/w159/ai-tech-toolkit/issues"
  },
  "homepage": "https://github.com/w159/ai-tech-toolkit/tree/main/mcp_servers/connectwise-manage-mcp",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "semantic-release": "^25.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
