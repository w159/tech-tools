{
  "name": "auvik-mcp",
  "version": "0.4.1",
  "description": "MCP server for the Auvik network monitoring API",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "pack:mcpb": "node scripts/pack-mcpb.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "fastify": "^5.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9",
    "semantic-release": "^25.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w159/tech-tools.git",
    "directory": "mcp_servers/auvik-mcp"
  },
  "homepage": "https://github.com/w159/tech-tools/tree/main/mcp_servers/auvik-mcp",
  "bugs": {
    "url": "https://github.com/w159/tech-tools/issues"
  }
}
