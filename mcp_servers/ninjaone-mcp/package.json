{
  "name": "ninjaone-mcp",
  "version": "1.6.1",
  "description": "NinjaOne MCP server with decision tree architecture for Claude",
  "type": "module",
  "main": "dist/mcp_servers/ninjaone-mcp/src/index.js",
  "types": "dist/mcp_servers/ninjaone-mcp/src/index.d.ts",
  "bin": {
    "ninjaone-mcp": "./dist/mcp_servers/ninjaone-mcp/src/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:mcpb": "node scripts/pack-mcpb.js",
    "validate:mcpb": "mcpb validate manifest.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w159/tech-tools.git",
    "directory": "mcp_servers/ninjaone-mcp"
  },
  "keywords": [
    "mcp",
    "claude",
    "ninjaone",
    "ninja",
    "rmm",
    "msp",
    "decision-tree"
  ],
  "author": "w159",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/w159/tech-tools/issues"
  },
  "homepage": "https://github.com/w159/tech-tools/tree/main/mcp_servers/ninjaone-mcp",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "node-ninjaone": "file:../../mcp_node/node-ninjaone"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "semantic-release": "^25.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
