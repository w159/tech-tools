{
  "mcpServers": {
    "pax8": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.pax8.com/v1/mcp",
        "--header",
        "x-pax8-mcp-token:${user_config.pax8_mcp_token}"
      ]
    },
    "pandadoc": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://developers.pandadoc.com/mcp",
        "--header",
        "Authorization:API-Key ${user_config.pandadoc_api_key}"
      ]
    }
  }
}
