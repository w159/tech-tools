{
  "mcpServers": {
    "auvik": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/launch.sh", "auvik-mcp", "dist/index.js"],
      "env": {
        "AUVIK_USERNAME": "${user_config.auvik_username}",
        "AUVIK_API_KEY": "${user_config.auvik_api_key}",
        "AUVIK_REGION": "${user_config.auvik_region}",
        "MCP_TRANSPORT": "stdio"
      }
    },
    "blumira": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/launch.sh", "blumira-mcp", "dist/index.js"],
      "env": {
        "BLUMIRA_JWT_TOKEN": "${user_config.blumira_jwt_token}",
        "BLUMIRA_CLIENT_ID": "${user_config.blumira_client_id}",
        "BLUMIRA_CLIENT_SECRET": "${user_config.blumira_client_secret}",
        "BLUMIRA_BASE_URL": "${user_config.blumira_base_url}",
        "MCP_TRANSPORT": "stdio"
      }
    },
    "cipp": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/launch.sh", "cipp-mcp", "dist/entry.js"],
      "env": {
        "CIPP_BASE_URL": "${user_config.cipp_base_url}",
        "CIPP_API_KEY": "${user_config.cipp_api_key}",
        "CIPP_TENANT_ID": "${user_config.cipp_tenant_id}",
        "CIPP_CLIENT_ID": "${user_config.cipp_client_id}",
        "CIPP_CLIENT_SECRET": "${user_config.cipp_client_secret}",
        "MCP_TRANSPORT": "stdio"
      }
    },
    "connectwise-manage": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/launch.sh", "connectwise-manage-mcp", "dist/index.js"],
      "env": {
        "CW_MANAGE_COMPANY_ID": "${user_config.cw_manage_company_id}",
        "CW_MANAGE_PUBLIC_KEY": "${user_config.cw_manage_public_key}",
        "CW_MANAGE_PRIVATE_KEY": "${user_config.cw_manage_private_key}",
        "CW_MANAGE_CLIENT_ID": "${user_config.cw_manage_client_id}",
        "CW_MANAGE_URL": "${user_config.cw_manage_base_url}",
        "MCP_TRANSPORT": "stdio"
      }
    },
    "spanning": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/launch.sh", "kaseya-spanning-backup-mcp", "dist/index.js"],
      "env": {
        "SPANNING_ADMIN_EMAIL": "${user_config.spanning_admin_email}",
        "SPANNING_API_TOKEN": "${user_config.spanning_api_token}",
        "SPANNING_PLATFORM": "${user_config.spanning_platform}",
        "SPANNING_API_URL": "${user_config.spanning_api_url}",
        "MCP_TRANSPORT": "stdio"
      }
    },
    "knowbe4": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/launch.sh", "knowbe4-mcp", "dist/mcp_servers/knowbe4-mcp/src/index.js"],
      "env": {
        "KNOWBE4_API_KEY": "${user_config.knowbe4_api_key}",
        "KNOWBE4_REGION": "${user_config.knowbe4_region}",
        "KNOWBE4_BASE_URL": "${user_config.knowbe4_base_url}",
        "MCP_TRANSPORT": "stdio"
      }
    },
    "ninjaone": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/launch.sh", "ninjaone-mcp", "dist/mcp_servers/ninjaone-mcp/src/index.js"],
      "env": {
        "NINJAONE_CLIENT_ID": "${user_config.ninjaone_client_id}",
        "NINJAONE_CLIENT_SECRET": "${user_config.ninjaone_client_secret}",
        "NINJAONE_REGION": "${user_config.ninjaone_region}",
        "NINJAONE_AUTH_MODE": "${user_config.ninjaone_auth_mode}",
        "NINJAONE_BASE_URL": "${user_config.ninjaone_base_url}",
        "MCP_TRANSPORT": "stdio"
      }
    },
    "paylocity": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/launch.sh", "paylocity-mcp", "dist/index.js"],
      "env": {
        "PAYLOCITY_CLIENT_ID": "${user_config.paylocity_client_id}",
        "PAYLOCITY_CLIENT_SECRET": "${user_config.paylocity_client_secret}",
        "PAYLOCITY_COMPANY_ID": "${user_config.paylocity_company_id}",
        "PAYLOCITY_BASE_URL": "${user_config.paylocity_base_url}",
        "PAYLOCITY_SANDBOX": "${user_config.paylocity_sandbox}",
        "MCP_TRANSPORT": "stdio"
      }
    },
    "threatlocker": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/launch.sh", "threatlocker-mcp", "dist/index.js"],
      "env": {
        "THREATLOCKER_API_KEY": "${user_config.threatlocker_api_key}",
        "THREATLOCKER_ORGANIZATION_ID": "${user_config.threatlocker_organization_id}",
        "THREATLOCKER_BASE_URL": "${user_config.threatlocker_base_url}",
        "MCP_TRANSPORT": "stdio"
      }
    },
    "vanta": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/launch.sh", "vanta-mcp", "dist/index.js"],
      "env": {
        "VANTA_CLIENT_ID": "${user_config.vanta_client_id}",
        "VANTA_CLIENT_SECRET": "${user_config.vanta_client_secret}",
        "VANTA_BASE_URL": "${user_config.vanta_base_url}",
        "MCP_TRANSPORT": "stdio"
      }
    }
  }
}
