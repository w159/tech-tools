{
  "name": "node-spanning",
  "version": "1.0.2",
  "type": "module",
  "description": "Typed Node.js client for the Spanning Cloud Backup REST API; used by kaseya-spanning-backup-mcp.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "spanning",
    "spanning-backup",
    "saas-backup",
    "m365",
    "google-workspace",
    "salesforce",
    "msp",
    "api",
    "typescript",
    "kaseya"
  ],
  "author": "w159",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w159/tech-tools.git",
    "directory": "mcp_node/node-spanning"
  },
  "bugs": {
    "url": "https://github.com/w159/tech-tools/issues"
  },
  "homepage": "https://github.com/w159/tech-tools/tree/main/mcp_node/node-spanning",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^8.56.0",
    "msw": "^2.1.0",
    "semantic-release": "^25.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
