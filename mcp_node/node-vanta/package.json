{
  "name": "node-vanta",
  "version": "1.0.0",
  "description": "Typed Node.js client for the Vanta REST API; used by vanta-mcp.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "author": "w159",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w159/ai-tech-toolkit.git",
    "directory": "mcp_node/node-vanta"
  },
  "bugs": {
    "url": "https://github.com/w159/ai-tech-toolkit/issues"
  },
  "homepage": "https://github.com/w159/ai-tech-toolkit/tree/main/mcp_node/node-vanta",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "msw": "^2.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  },
  "dependencies": {}
}
